#!/usr/bin/env bash
# cdx-hud-render — render loop for the Codex HUD.
# Tails the latest ~/.codex/sessions/**/rollout-*.jsonl and redraws every REFRESH_INTERVAL.
# Designed to run inside a dedicated tmux pane spawned by `cdx-hud`.

set -u

CODEX_HOME="${CODEX_HOME:-$HOME/.codex}"
SESSIONS_DIR="$CODEX_HOME/sessions"
REFRESH_INTERVAL="${CDX_HUD_REFRESH:-5}"

# Optional: pin the HUD to a specific rollout file (set by cdx-hud wrapper)
PINNED_ROLLOUT="${CDX_HUD_ROLLOUT:-}"

# Debug log — set CDX_HUD_DEBUG=1 to capture stderr + per-tick state to a
# file you can `tail -f` while reproducing an issue.
DEBUG_LOG="$CODEX_HOME/cdx-hud-debug.log"
if [ "${CDX_HUD_DEBUG:-0}" = "1" ]; then
  : > "$DEBUG_LOG" 2>/dev/null || DEBUG_LOG=""
  if [ -n "$DEBUG_LOG" ]; then
    exec 2>>"$DEBUG_LOG"
    printf '[%s] cdx-hud-render starting (pid=%s, codex_home=%s)\n' \
      "$(date '+%H:%M:%S')" "$$" "$CODEX_HOME" >&2
  fi
fi
debug_log() {
  [ "${CDX_HUD_DEBUG:-0}" = "1" ] || return 0
  printf '[%s] %s\n' "$(date '+%H:%M:%S')" "$*" >&2
}

# Detect once which stat(1) flag returns mtime as Unix epoch seconds.
# macOS / BSD: `stat -f %m`. GNU coreutils (Linux): `stat -c %Y`.
if stat -f %m / >/dev/null 2>&1; then
  STAT_MTIME_FMT="-f %m"
elif stat -c %Y / >/dev/null 2>&1; then
  STAT_MTIME_FMT="-c %Y"
else
  echo "cdx-hud-render: stat(1) supports neither -f %m nor -c %Y; cannot run." >&2
  exit 1
fi

# ─── helpers ─────────────────────────────────────────────────────────────────

# Read mtime (Unix epoch seconds) of a file. Returns 0 if the file is missing
# or stat fails so callers can use the result in arithmetic safely.
file_mtime() {
  stat $STAT_MTIME_FMT "$1" 2>/dev/null || echo 0
}

# Extract the session UUID from a rollout filename.
#   rollout-YYYY-MM-DDTHH-MM-SS-<UUID>.jsonl  →  <UUID>
rollout_uuid() {
  local base=${1##*/}
  base=${base%.jsonl}
  echo "${base#rollout-????-??-??T??-??-??-}"
}

# Extract the session UUID from a shell-snapshot filename.
#   <UUID>.<ns_timestamp>.sh  →  <UUID>
snapshot_uuid() {
  local base=${1##*/}
  echo "${base%%.*}"
}

fmt_remaining() {
  local secs=$(( $1 - $(date +%s) ))
  (( secs <= 0 )) && { echo "now"; return; }
  local d=$((secs/86400)) h=$(((secs%86400)/3600)) m=$(((secs%3600)/60))
  if   (( d > 0 )); then echo "${d}d${h}h"
  elif (( h > 0 )); then echo "${h}h${m}m"
  else                   echo "${m}m"
  fi
}

# Pick ANSI color escape for a percentage, escalating: base → yellow ≥70 → bold bright red ≥90
threshold_color() {
  local pct=$1 base=$2
  if awk "BEGIN{exit !($pct >= 90)}" 2>/dev/null; then echo "1;91"
  elif awk "BEGIN{exit !($pct >= 70)}" 2>/dev/null; then echo "33"
  else echo "$base"
  fi
}

# Read default model + reasoning_effort from ~/.codex/config.toml.
# Used as a fallback when the active session has no turn_context event yet.
# Output format: "model|effort" (either side may be empty).
read_config_defaults() {
  local cfg="$CODEX_HOME/config.toml"
  [ -f "$cfg" ] || { printf '|\n'; return; }
  # Only read model + reasoning_effort from the top-level table (before the
  # first `[section]` line). Without the boundary, the regex would match keys
  # under [profiles.foo], [mcp_servers.bar], etc., which can have their own
  # `model = "..."` overrides unrelated to the user's actual default.
  local m e
  m=$(awk '/^[[:space:]]*\[/ {exit}
           /^[[:space:]]*model[[:space:]]*=/ { sub(/^[^=]*=[[:space:]]*/, ""); sub(/[[:space:]]*#.*$/, ""); gsub(/^["'\'']|["'\'']$/, ""); print; exit }' "$cfg" 2>/dev/null)
  e=$(awk '/^[[:space:]]*\[/ {exit}
           /^[[:space:]]*model_reasoning_effort[[:space:]]*=/ { sub(/^[^=]*=[[:space:]]*/, ""); sub(/[[:space:]]*#.*$/, ""); gsub(/^["'\'']|["'\'']$/, ""); print; exit }' "$cfg" 2>/dev/null)
  printf '%s|%s\n' "$m" "$e"
}

human_tokens() {
  local n=${1:-0}
  if [ "$n" -ge 1000000 ]; then awk "BEGIN { printf \"%.1fM\", $n / 1000000 }"
  elif [ "$n" -ge 1000 ]; then awk "BEGIN { printf \"%.0fk\", $n / 1000 }"
  else echo "$n"
  fi
}

find_latest_rollout() {
  if [ -n "$PINNED_ROLLOUT" ] && [ -f "$PINNED_ROLLOUT" ]; then
    printf '%s\n' "$PINNED_ROLLOUT"; return
  fi
  find "$SESSIONS_DIR" -name "rollout-*.jsonl" -type f 2>/dev/null \
    | sort | tail -1
}

# Detect the *active* session this HUD instance was launched alongside.
# When CDX_HUD_START_EPOCH is set (by the cdx-hud wrapper), prefer the most
# recently modified shell_snapshot or rollout file with mtime ≥ that epoch.
# Returns: "<UUID>|<rollout_path_or_empty>" — empty rollout path means the
# session has no JSONL events yet (just opened).
detect_active_session() {
  # Once we've resolved a stable session (UUID + actual rollout path), pin it
  # to skip find/scan operations per tick and to prevent two concurrent cdx
  # instances launched within the cutoff slack window from stealing each
  # other's session.
  #
  # BUT — codex's /resume command opens a previous rollout in-place. The
  # initial signal is a fresh shell_snapshot for the resumed session UUID;
  # the rollout file itself isn't touched until the user actually sends a
  # message. So both rollouts AND snapshots can be the "newer" signal that
  # invalidates the pin.
  if [ -n "${_PINNED_UUID:-}" ] && [ -n "${_PINNED_ROLLOUT:-}" ] \
     && [ -f "$_PINNED_ROLLOUT" ]; then
    local newer_rollout newer_snapshot
    newer_rollout=$(find "$SESSIONS_DIR" -name 'rollout-*.jsonl' -type f -newer "$_PINNED_ROLLOUT" 2>/dev/null | head -1)
    newer_snapshot=""
    if [ -d "$CODEX_HOME/shell_snapshots" ]; then
      newer_snapshot=$(find "$CODEX_HOME/shell_snapshots" -name '*.sh' -type f -newer "$_PINNED_ROLLOUT" 2>/dev/null | head -1)
    fi
    if [ -z "$newer_rollout" ] && [ -z "$newer_snapshot" ]; then
      printf '%s|%s\n' "$_PINNED_UUID" "$_PINNED_ROLLOUT"
      return
    fi
    debug_log "detect_active_session: pin invalidated — newer ${newer_rollout:+rollout }${newer_snapshot:+snapshot }detected (likely /resume)"
    _PINNED_UUID=""
    _PINNED_ROLLOUT=""
  fi

  local cutoff="${CDX_HUD_START_EPOCH:-0}"
  # Allow ~5s of clock-skew slack so rollouts created right before the wrapper
  # ran still count if their first event is mid-flight.
  cutoff=$(( cutoff > 5 ? cutoff - 5 : 0 ))

  local newest_uuid="" newest_mtime=0 newest_rollout=""

  # Shell snapshots (created at session start, named <UUID>.<ns_timestamp>.sh)
  if [ -d "$CODEX_HOME/shell_snapshots" ]; then
    local f mtime uuid
    for f in "$CODEX_HOME/shell_snapshots"/*.sh; do
      [ -e "$f" ] || continue
      mtime=$(file_mtime "$f")
      [ "$mtime" -lt "$cutoff" ] && continue
      if [ "$mtime" -gt "$newest_mtime" ]; then
        newest_mtime=$mtime
        newest_uuid=$(snapshot_uuid "$f")
        newest_rollout=""
      fi
    done
  fi

  # Rollouts
  local f mtime
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    mtime=$(file_mtime "$f")
    [ "$mtime" -lt "$cutoff" ] && continue
    if [ "$mtime" -gt "$newest_mtime" ]; then
      newest_mtime=$mtime
      newest_uuid=$(rollout_uuid "$f")
      newest_rollout="$f"
    fi
  done < <(find "$SESSIONS_DIR" -name "rollout-*.jsonl" -type f 2>/dev/null | sort | tail -10)

  # If a fresh shell_snapshot won the UUID race but no rollout was touched
  # within the cutoff (typical right after /resume — codex creates a new
  # snapshot but doesn't write to the rollout until the user sends a turn),
  # locate the matching rollout by UUID. Otherwise we'd treat the resumed
  # session as "loading" and ignore its rich history.
  if [ -n "$newest_uuid" ] && [ -z "$newest_rollout" ]; then
    local match
    match=$(find "$SESSIONS_DIR" -name "rollout-*-$newest_uuid.jsonl" -type f 2>/dev/null | head -1)
    if [ -n "$match" ]; then
      newest_rollout="$match"
      debug_log "detect_active_session: matched snapshot UUID to rollout: $match"
    fi
  fi

  # If we have no wrapper context (no start epoch), fall back to the most recent
  # rollout. With wrapper context, an empty result means "loading" — the caller
  # will render a placeholder rather than show stale prior-session data.
  if [ -z "$newest_uuid" ] && [ -z "${CDX_HUD_START_EPOCH:-}" ]; then
    local f
    f=$(find_latest_rollout)
    if [ -n "$f" ]; then
      newest_rollout="$f"
      newest_uuid=$(rollout_uuid "$f")
    fi
  fi

  debug_log "detect_active_session: uuid=${newest_uuid:-<none>} rollout=${newest_rollout:-<none>} cutoff=$cutoff"

  # Pin only when we have BOTH a UUID and a rollout file; the pure-snapshot case
  # (UUID known, rollout not yet flushed) stays unpinned so we keep polling for
  # the rollout to appear.
  if [ -n "$newest_uuid" ] && [ -n "$newest_rollout" ]; then
    _PINNED_UUID="$newest_uuid"
    _PINNED_ROLLOUT="$newest_rollout"
    debug_log "detect_active_session: pinned for the rest of this render"
  fi

  printf '%s|%s\n' "$newest_uuid" "$newest_rollout"
}

# Recent rollouts, oldest → newest. Used to recover last-known rate limit state
# across session boundaries (e.g., when the current session opens already
# rate-limited and reports primary=null, secondary=null from the start).
find_recent_rollouts() {
  if [ -n "$PINNED_ROLLOUT" ] && [ -f "$PINNED_ROLLOUT" ]; then
    printf '%s\n' "$PINNED_ROLLOUT"; return
  fi
  find "$SESSIONS_DIR" -name "rollout-*.jsonl" -type f 2>/dev/null \
    | sort | tail -5
}

# Get git branch + dirty + ahead/behind for a directory
git_segment() {
  local cwd="$1"
  [ -z "$cwd" ] || [ ! -d "$cwd" ] && return
  git -C "$cwd" rev-parse --is-inside-work-tree >/dev/null 2>&1 || return
  local branch dirty ab a b ahead_behind=""
  branch=$(git -C "$cwd" -c gc.auto=0 symbolic-ref --short HEAD 2>/dev/null \
    || git -C "$cwd" rev-parse --short HEAD 2>/dev/null)
  [ -n "$(git -C "$cwd" -c gc.auto=0 status --porcelain 2>/dev/null)" ] && dirty="*"
  ab=$(git -C "$cwd" -c gc.auto=0 rev-list --left-right --count HEAD...@{upstream} 2>/dev/null)
  if [ -n "$ab" ]; then
    a=$(printf '%s' "$ab" | awk '{print $1}')
    b=$(printf '%s' "$ab" | awk '{print $2}')
    [ "${a:-0}" -gt 0 ] 2>/dev/null && ahead_behind+="↑$a"
    [ "${b:-0}" -gt 0 ] 2>/dev/null && ahead_behind+="${ahead_behind:+ }↓$b"
  fi
  printf '(%s%s)%s' "$branch" "$dirty" "${ahead_behind:+ $ahead_behind}"
}

# ─── extraction ──────────────────────────────────────────────────────────────

extract_state() {
  # Reduce the last few rollouts (oldest → newest) into a single state object.
  # Cross-session tracking is needed because Codex emits primary=null/secondary=null
  # the moment a limit is hit, so a session opened *after* the hit has no live
  # data — we recover the last-known used_percent from prior sessions.
  local files=()
  while IFS= read -r f; do [ -n "$f" ] && files+=("$f"); done < <(find_recent_rollouts)

  local active_uuid="" active_rollout=""
  IFS='|' read -r active_uuid active_rollout < <(detect_active_session)

  # If the active session has its own rollout, force it to be processed LAST
  # in jq order — irrespective of where filename-sort placed it. find_recent_rollouts
  # sorts by name; codex's /resume command resumes a previous (older-named)
  # rollout while keeping it filename-stable, so without this re-ordering the
  # LAST session_meta jq sees would belong to whichever rollout sorted last by
  # filename, not the one the user is actually in.
  # The ${files[@]+"${files[@]}"} guard works around macOS bash 3.2: under
  # `set -u`, expanding an empty "${arr[@]}" raises "unbound variable".
  if [ -n "$active_rollout" ] && [ -f "$active_rollout" ]; then
    local filtered=() f
    for f in ${files[@]+"${files[@]}"}; do
      [ "$f" != "$active_rollout" ] && filtered+=("$f")
    done
    filtered+=("$active_rollout")
    files=(${filtered[@]+"${filtered[@]}"})
  fi

  # Cache by mtime signature: if every input file's mtime is unchanged from
  # the last call, the jq output cannot have changed either (rollouts are
  # append-only, and rate-limit reset checks vs $now have at most a 5s lag
  # which the next tick will catch). Skips re-cat-ing potentially-multi-MB
  # rollouts when nothing's happened.
  local sig=""
  for f in ${files[@]+"${files[@]}"}; do
    sig+="$(file_mtime "$f"):$f|"
  done
  sig+="active=$active_uuid"
  if [ "$sig" = "${_STATE_CACHE_KEY:-}" ] && [ -n "${_STATE_CACHE_VALUE:-}" ]; then
    printf '%s' "$_STATE_CACHE_VALUE"
    return
  fi

  # Loading state: wrapper launched us, but no rollout/snapshot has yet been
  # written for the new session. We still want to surface cross-session rate
  # limits, but per-session fields (model, context, session id) must not be
  # taken from the prior session — show a "loading" placeholder instead.
  local loading=0
  if [ -n "${CDX_HUD_START_EPOCH:-}" ] && [ -z "$active_uuid" ]; then
    loading=1
  fi

  [ ${#files[@]} -eq 0 ] && {
    [ -n "$active_uuid" ] && printf 'META_ID=%s\n' "$active_uuid"
    [ "$loading" = "1" ] && printf 'LOADING=1\n'
    return
  }

  local now
  now=$(date +%s)

  local _state_output
  _state_output=$(cat "${files[@]}" 2>/dev/null | jq -rn --argjson now "$now" --argjson loading "$loading" --arg active_id "$active_uuid" '
    # Coerce a resets_at value (number, ISO-8601 string, or null) to epoch seconds.
    # Future Codex builds may emit ISO; current builds emit Unix seconds. Without
    # this, an ISO string would silently parse as 0 and trigger the stale-wipe.
    def to_epoch: (tonumber? // fromdateiso8601? // 0);

    # Threshold above which a stale-but-recent value is treated as "hit".
    90 as $hit_thresh
    | [inputs] as $items
    | reduce $items[] as $r (
        {meta_id:"", meta_cwd:"", meta_version:"",
         tok_ctx:0, tok_window:0, tok_session_total:0,
         rl_primary_pct:"", rl_primary_reset:"", rl_primary_win:"", rl_primary_currently_null:0,
         rl_secondary_pct:"", rl_secondary_reset:"", rl_secondary_win:"", rl_secondary_currently_null:0,
         rl_plan:"", rl_limit_id:"",
         turn_model:"", turn_effort:"", turn_cwd:"",
         turn_approval:"", turn_sandbox:""};
        if $r.type == "session_meta" then
          .meta_id = ($r.payload.id // "")
          | .meta_cwd = ($r.payload.cwd // "")
          | .meta_version = ($r.payload.cli_version // "")
          # Reset per-session live state when crossing session boundaries.
          # tok_window stays since it is a model property that survives sessions.
          | .tok_ctx = 0
          | .tok_session_total = 0
          | .turn_model = ""
          | .turn_effort = ""
          | .turn_cwd = ""
          | .turn_approval = ""
          | .turn_sandbox = ""
        elif $r.payload.type == "token_count" then
          # Token usage block is null when the session opens already rate-limited.
          # Only overwrite when fresh data exists; otherwise preserve last known.
          (if $r.payload.info != null then
             .tok_ctx = ($r.payload.info.last_token_usage.input_tokens // 0)
             | .tok_session_total = ($r.payload.info.total_token_usage.total_tokens // 0)
             | (if ($r.payload.info.model_context_window // 0) > 0 then
                  .tok_window = $r.payload.info.model_context_window
                else . end)
           else . end)
          | .rl_plan = ($r.payload.rate_limits.plan_type // .rl_plan)
          | .rl_limit_id = ($r.payload.rate_limits.limit_id // .rl_limit_id)
          # Primary: only overwrite last-known when fresh data exists
          | (if $r.payload.rate_limits.primary != null then
               .rl_primary_pct = ($r.payload.rate_limits.primary.used_percent // "" | tostring)
               | .rl_primary_reset = (($r.payload.rate_limits.primary.resets_at | to_epoch) | tostring)
               | .rl_primary_win = ($r.payload.rate_limits.primary.window_minutes // "" | tostring)
               | .rl_primary_currently_null = 0
             else
               .rl_primary_currently_null = 1
             end)
          # Secondary: same
          | (if $r.payload.rate_limits.secondary != null then
               .rl_secondary_pct = ($r.payload.rate_limits.secondary.used_percent // "" | tostring)
               | .rl_secondary_reset = (($r.payload.rate_limits.secondary.resets_at | to_epoch) | tostring)
               | .rl_secondary_win = ($r.payload.rate_limits.secondary.window_minutes // "" | tostring)
               | .rl_secondary_currently_null = 0
             else
               .rl_secondary_currently_null = 1
             end)
        elif $r.type == "turn_context" then
          .turn_model = ($r.payload.model // .turn_model)
          | .turn_effort = ($r.payload.effort // .turn_effort)
          | .turn_cwd = ($r.payload.cwd // .turn_cwd)
          | .turn_approval = ($r.payload.approval_policy // .turn_approval)
          | .turn_sandbox = ($r.payload.sandbox_policy.type // .turn_sandbox)
        else . end
      )
    # If last-known reset has already passed, the data is stale to the point of
    # uselessness — drop it so we render nothing rather than wrong numbers.
    | (if (.rl_primary_reset | tonumber? // 0) > 0 and (.rl_primary_reset | tonumber) <= $now then
         .rl_primary_pct = "" | .rl_primary_reset = "" | .rl_primary_win = ""
       else . end)
    | (if (.rl_secondary_reset | tonumber? // 0) > 0 and (.rl_secondary_reset | tonumber) <= $now then
         .rl_secondary_pct = "" | .rl_secondary_reset = "" | .rl_secondary_win = ""
       else . end)
    # Hit: latest event has it null AND last-known pct ≥ threshold AND reset is still in the future
    | .rl_primary_hit = (if .rl_primary_currently_null == 1
                            and (.rl_primary_pct | tonumber? // 0) >= $hit_thresh
                            and (.rl_primary_reset | tonumber? // 0) > $now
                           then 1 else 0 end)
    | .rl_primary_stale = (if .rl_primary_currently_null == 1 and .rl_primary_hit == 0 and (.rl_primary_pct | length) > 0 then 1 else 0 end)
    | .rl_secondary_hit = (if .rl_secondary_currently_null == 1
                              and (.rl_secondary_pct | tonumber? // 0) >= $hit_thresh
                              and (.rl_secondary_reset | tonumber? // 0) > $now
                             then 1 else 0 end)
    | .rl_secondary_stale = (if .rl_secondary_currently_null == 1 and .rl_secondary_hit == 0 and (.rl_secondary_pct | length) > 0 then 1 else 0 end)
    # Loading state: wipe per-session fields so we never display the prior
    # session as if it were the current one. Rate-limit fields stay (account-wide).
    | (if $loading == 1 then
         .meta_id = "" | .tok_ctx = 0 | .tok_session_total = 0
         | .turn_model = "" | .turn_effort = "" | .turn_cwd = ""
         | .turn_approval = "" | .turn_sandbox = ""
       elif ($active_id // "") != "" and .meta_id != $active_id then
         # Wrapper detected a session id different from the last we saw events
         # for — zero per-session fields rather than show stale numbers.
         .meta_id = $active_id | .tok_ctx = 0 | .tok_session_total = 0
         | .turn_model = "" | .turn_effort = "" | .turn_cwd = ""
         | .turn_approval = "" | .turn_sandbox = ""
       else . end)
    | . + {loading: $loading}
    # Tab-separated KEY \t VALUE so the bash side can read without eval.
    | to_entries[] | "\(.key | ascii_upcase)\t\(.value)"
  ' 2>/dev/null)

  _STATE_CACHE_KEY="$sig"
  _STATE_CACHE_VALUE="$_state_output"
  printf '%s\n' "$_state_output"
}

# ─── render ──────────────────────────────────────────────────────────────────

render_once() {
  local rollout
  rollout=$(find_latest_rollout)

  # Full-screen clear before each redraw. We use \033[2J (clear entire screen)
  # rather than \033[J (clear-from-cursor-down) so a terminal resize that left
  # wider stale content on lower rows doesn't bleed through — \033[K only
  # clears one line.
  printf '\033[2J\033[H'

  if [ -z "$rollout" ]; then
    printf '\033[90m(waiting for codex session…)\033[0m\n'
    return
  fi

  # Reset all extractable vars before sourcing — older sessions may lack newer fields
  META_ID="" META_CWD="" META_VERSION=""
  TOK_CTX="" TOK_SESSION_TOTAL="" TOK_WINDOW=""
  RL_PRIMARY_PCT="" RL_PRIMARY_RESET="" RL_PRIMARY_WIN=""
  RL_PRIMARY_CURRENTLY_NULL="" RL_PRIMARY_HIT="" RL_PRIMARY_STALE=""
  RL_SECONDARY_PCT="" RL_SECONDARY_RESET="" RL_SECONDARY_WIN=""
  RL_SECONDARY_CURRENTLY_NULL="" RL_SECONDARY_HIT="" RL_SECONDARY_STALE=""
  RL_PLAN="" RL_LIMIT_ID="" LOADING=""
  TURN_MODEL="" TURN_EFFORT="" TURN_CWD=""
  TURN_APPROVAL="" TURN_SANDBOX=""

  # Read tab-separated KEY \t VALUE pairs from extract_state. We deliberately
  # avoid eval so a path/model/cwd containing $(…), backticks, ; or quotes
  # cannot execute. Key is whitelist-validated; value is set via printf -v.
  local _k _v
  while IFS=$'\t' read -r _k _v; do
    [ -z "$_k" ] && continue
    case "$_k" in
      [A-Z_][A-Z0-9_]*) printf -v "$_k" '%s' "$_v" ;;
    esac
  done < <(extract_state "$rollout")
  debug_log "render: meta_id=${META_ID:-<empty>} model=${TURN_MODEL:-<empty>} loading=${LOADING:-<empty>} ctx=${TOK_CTX:-<empty>}/${TOK_WINDOW:-<empty>} 5h=${RL_PRIMARY_PCT:-<empty>}(hit=${RL_PRIMARY_HIT:-0}) 7d=${RL_SECONDARY_PCT:-<empty>}(hit=${RL_SECONDARY_HIT:-0})"

  local cwd="${TURN_CWD:-${META_CWD:-$PWD}}"

  # Fall back to config.toml defaults when the rollout has no turn_context yet.
  local default_model="" default_effort=""
  IFS='|' read -r default_model default_effort < <(read_config_defaults)

  local model="${TURN_MODEL:-$default_model}"
  local effort="${TURN_EFFORT:-$default_effort}"
  local session_id="$META_ID"

  # ── line 1 parts ─────────────────────────────────────────────────
  local line1=()

  if [ "$LOADING" = "1" ]; then
    line1+=("$(printf '\033[38;2;167;139;250mLoading Codex session…\033[0m')")
  else
    # model (Claude purple #a78bfa)
    local model_label="${model:-?}"
    [ -n "$effort" ] && model_label="$model_label ($effort)"
    line1+=("$(printf '\033[38;2;167;139;250m%s\033[0m' "$model_label")")
  fi

  # context % — based on last input tokens vs model context window
  if [ "$LOADING" != "1" ] && [ -n "$TOK_CTX" ] && [ -n "$TOK_WINDOW" ] && [ "$TOK_WINDOW" -gt 0 ]; then
    local ctx_pct
    ctx_pct=$(awk "BEGIN { printf \"%.0f\", $TOK_CTX * 100 / $TOK_WINDOW }")
    local ctx_color
    ctx_color=$(threshold_color "$ctx_pct" 32)
    local human
    human=$(human_tokens "$TOK_CTX")
    line1+=("$(printf '\033[%sm%s%% (~%s)\033[0m' "$ctx_color" "$ctx_pct" "$human")")
  fi

  # rate limits (suppressed during loading — line 1 stays a single segment)
  local rate_parts=()
  if [ "$LOADING" != "1" ]; then
  if [ "$RL_PRIMARY_HIT" = "1" ]; then
    local s="5h:100%"
    if [ -n "$RL_PRIMARY_RESET" ]; then
      s="$s (hit, $(fmt_remaining "$RL_PRIMARY_RESET"))"
    else
      s="$s (hit)"
    fi
    rate_parts+=("$(printf '\033[1;91m%s\033[0m' "$s")")
  elif [ -n "$RL_PRIMARY_PCT" ]; then
    local s c
    s="5h:$(printf '%.0f' "$RL_PRIMARY_PCT")%"
    [ -n "$RL_PRIMARY_RESET" ] && s="$s ($(fmt_remaining "$RL_PRIMARY_RESET"))"
    c=$(threshold_color "$RL_PRIMARY_PCT" "38;2;120;160;230")
    rate_parts+=("$(printf '\033[%sm%s\033[0m' "$c" "$s")")
  fi
  [ "$RL_PRIMARY_STALE" = "1" ] && rate_parts[${#rate_parts[@]}-1]+=$(printf '\033[90m*\033[0m')
  if [ "$RL_SECONDARY_HIT" = "1" ]; then
    local s="7d:100%"
    if [ -n "$RL_SECONDARY_RESET" ]; then
      s="$s (hit, $(fmt_remaining "$RL_SECONDARY_RESET"))"
    else
      s="$s (hit)"
    fi
    rate_parts+=("$(printf '\033[1;91m%s\033[0m' "$s")")
  elif [ -n "$RL_SECONDARY_PCT" ]; then
    local s c
    s="7d:$(printf '%.0f' "$RL_SECONDARY_PCT")%"
    [ -n "$RL_SECONDARY_RESET" ] && s="$s ($(fmt_remaining "$RL_SECONDARY_RESET"))"
    c=$(threshold_color "$RL_SECONDARY_PCT" "38;2;120;160;230")
    rate_parts+=("$(printf '\033[%sm%s\033[0m' "$c" "$s")")
  fi
  [ "$RL_SECONDARY_STALE" = "1" ] && rate_parts[${#rate_parts[@]}-1]+=$(printf '\033[90m*\033[0m')
  if [ ${#rate_parts[@]} -gt 0 ]; then
    local joined="${rate_parts[0]}"
    local r
    for r in "${rate_parts[@]:1}"; do joined+=" $r"; done
    line1+=("$joined")
  fi
  fi  # end LOADING != 1

  # session id (dim grey) — hidden during loading
  if [ "$LOADING" != "1" ] && [ -n "$session_id" ]; then
    line1+=("$(printf '\033[90m%s\033[0m' "$session_id")")
  fi

  # ── line 2 parts ─────────────────────────────────────────────────
  local line2=()
  # Replace leading $HOME with ~ via literal prefix-strip + concat, not the
  # ${var/#PAT/REPL} form (which treats PAT as a glob, so a $HOME containing
  # '[', '*', or '?' would mis-replace).
  local display_cwd="$cwd"
  if [ -n "$HOME" ] && [ "${cwd#$HOME}" != "$cwd" ]; then
    display_cwd="~${cwd#$HOME}"
  fi
  [ -n "$display_cwd" ] && [ "${display_cwd: -1}" != "/" ] && display_cwd="$display_cwd/"
  [ -n "$display_cwd" ] && line2+=("$(printf '\033[36m%s\033[0m' "$display_cwd")")

  local git_label
  git_label=$(git_segment "$cwd")
  if [ -n "$git_label" ]; then
    line2+=("$(printf '\033[33m%s\033[0m' "$git_label")")
  else
    line2+=("$(printf '\033[90mNo Git\033[0m')")
  fi

  # ── line 3: YOLO banner (only when active and not in loading state) ──
  local line3=""
  if [ "$LOADING" != "1" ]; then
    if [ "${CDX_HUD_YOLO:-}" = "1" ] \
       || { [ "$TURN_APPROVAL" = "never" ] && [ "$TURN_SANDBOX" = "danger-full-access" ]; }; then
      line3=$(printf '\033[38;2;255;94;125m▶▶ yolo mode on\033[0m')
    fi
  fi

  # ── output ────────────────────────────────────────────────────────
  # Build all rendered lines into an array; print with `\n` BETWEEN them
  # (no trailing newline), so cursor stays inside the pane's visible area
  # and the first line never scrolls off the top.
  local lines=() out p
  if [ ${#line1[@]} -gt 0 ]; then
    out="${line1[0]}"
    for p in "${line1[@]:1}"; do
      out+=$(printf ' \033[90m|\033[0m %s' "$p")
    done
    lines+=("$out")
  fi
  if [ ${#line2[@]} -gt 0 ]; then
    out="${line2[0]}"
    for p in "${line2[@]:1}"; do
      out+=$(printf ' \033[90m|\033[0m %s' "$p")
    done
    lines+=("$out")
  fi
  [ -n "$line3" ] && lines+=("$line3")

  local i=0
  for out in ${lines[@]+"${lines[@]}"}; do
    if [ "$i" -eq 0 ]; then
      printf '  %s\033[K' "$out"
    else
      printf '\n  %s\033[K' "$out"
    fi
    i=$((i + 1))
  done
}

# ─── main loop ───────────────────────────────────────────────────────────────

# Enter alternate screen (isolated buffer, no scrollback pollution) + hide cursor.
# Restored on exit even if killed.
trap 'printf "\033[?25h\033[?1049l"' EXIT INT TERM HUP QUIT
printf '\033[?1049h\033[?25l'

# Poll quickly while in the "Loading session…" state so first real data
# shows up promptly; back off to the normal interval once data arrives.
LOADING_REFRESH="${CDX_HUD_LOADING_REFRESH:-0.3}"

# Watchdog: if the wrapper told us which pane runs codex, self-terminate
# the moment that pane disappears. Belt-and-suspenders to the wrapper's
# EXIT trap so an orphaned HUD pane never traps the user's terminal.
codex_pane_gone() {
  [ -z "${CDX_HUD_CODEX_PANE:-}" ] && return 1
  command -v tmux >/dev/null 2>&1 || return 1
  # list-panes -t <pane> exits non-zero with "can't find pane" when the target
  # is gone. Targeted lookup, no scan over every pane on the tmux server.
  ! tmux list-panes -t "$CDX_HUD_CODEX_PANE" >/dev/null 2>&1
}

while :; do
  render_once
  if codex_pane_gone; then
    exit 0
  fi
  if [ "${LOADING:-0}" = "1" ]; then
    sleep "$LOADING_REFRESH"
  else
    sleep "$REFRESH_INTERVAL"
  fi
done
