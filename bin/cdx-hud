#!/usr/bin/env bash
# cdx-hud — launches Codex CLI inside a tmux session with a persistent HUD pane.
# All extra args are forwarded to `codex`.

set -u

# Default to plain codex. Set CDX_HUD_CODEX_CMD to switch to YOLO mode
# or any other invocation (see the cdx / cdxy zsh aliases).
CODEX_CMD="${CDX_HUD_CODEX_CMD:-codex}"
HUD_HEIGHT="${CDX_HUD_HEIGHT:-3}"
SESSION_PREFIX="${CDX_HUD_SESSION_PREFIX:-cdxhud}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RENDER_BIN="$SCRIPT_DIR/cdx-hud-render"

if ! command -v tmux >/dev/null 2>&1; then
  echo "cdx-hud: tmux is required (brew install tmux)" >&2
  exit 1
fi
if [ ! -x "$RENDER_BIN" ]; then
  echo "cdx-hud: render script missing or not executable: $RENDER_BIN" >&2
  exit 1
fi

# Build the codex command, escaping forwarded args for the shell.
codex_full="$CODEX_CMD"
for arg in "$@"; do
  codex_full="$codex_full $(printf '%q' "$arg")"
done

cwd_q=$(printf '%q' "$PWD")
render_bin_q=$(printf '%q' "$RENDER_BIN")
start_epoch=$(date +%s)

# Hint the render of YOLO mode immediately, even before turn_context flushes.
# Walk the codex invocation and forwarded args looking for an EXACT match
# on the bypass flag — substring matches (e.g. a path argument literally
# named "--dangerously-bypass-approvals-and-sandbox") would false-positive.
yolo_hint=""
for _arg in $CODEX_CMD "$@"; do
  if [ "$_arg" = "--dangerously-bypass-approvals-and-sandbox" ]; then
    yolo_hint="CDX_HUD_YOLO=1"
    break
  fi
done
unset _arg

# YOLO adds a third visible row; size the HUD pane to keep exactly one
# blank padding row at the bottom in either case (3 without yolo, 4 with).
# Skipped when CDX_HUD_HEIGHT is set explicitly by the user.
if [ -z "${CDX_HUD_HEIGHT:-}" ] && [ -n "$yolo_hint" ]; then
  HUD_HEIGHT=4
fi

# If we're already inside tmux, just split and run codex in the current pane;
# otherwise create a new tmux session and attach.
if [ -n "${TMUX:-}" ]; then
  # Capture the current pane (will host codex) so the HUD can watchdog it.
  codex_pane=$(tmux display-message -p '#{pane_id}')
  # Split a HUD pane BELOW the current pane, then return focus to the original.
  hud_pane=$(tmux split-window -v -l "$HUD_HEIGHT" -P -F "#{pane_id}" \
    "CDX_HUD_START_EPOCH=$start_epoch CDX_HUD_CODEX_PANE=$codex_pane CDX_HUD_LAUNCH_CWD=$cwd_q $yolo_hint exec $render_bin_q")
  tmux select-pane -U
  # Pin HUD height across terminal resizes (zoom in/out) — tmux's default
  # behavior is proportional shrink, which would clip our content.
  current_window=$(tmux display-message -p '#{window_id}')
  tmux set-hook -t "$current_window" -w client-resized \
    "resize-pane -t $hud_pane -y $HUD_HEIGHT" 2>/dev/null || true
  tmux set-hook -t "$current_window" -w window-resized \
    "resize-pane -t $hud_pane -y $HUD_HEIGHT" 2>/dev/null || true
  # EXIT trap (also INT/TERM/HUP) ensures kill-pane and hook cleanup even if
  # the shell itself receives SIGINT alongside codex on Ctrl+C.
  exec bash -c "trap 'tmux kill-pane -t $hud_pane 2>/dev/null; tmux set-hook -u -t $current_window -w client-resized 2>/dev/null; tmux set-hook -u -t $current_window -w window-resized 2>/dev/null' EXIT INT TERM HUP; cd $cwd_q && $codex_full"
fi

session="${SESSION_PREFIX}-$$"
# Main pane runs codex via a one-shot dispatch script that:
#   1. Carries an EXIT/INT/TERM/HUP trap to kill-session even if its bash dies
#      from SIGINT alongside codex on Ctrl+C (otherwise the HUD pane orphans).
#   2. Cleans itself up on exit.
#   3. Avoids the nested `tmux's sh -c → bash -c "..."` double-parse where
#      our %q-escaped codex args would re-expand and break on $, backticks, !.
# The dispatch file is executed directly by tmux (one shell parse), so a single
# round of %q-escaping in $codex_full / $cwd_q is sufficient.
dispatch_file=$(mktemp -t cdxhud.XXXXXX)
chmod +x "$dispatch_file"
cat > "$dispatch_file" <<EOF
#!/usr/bin/env bash
# NOTE: do NOT 'exec' codex here — exec replaces the bash process and the
# EXIT trap goes with it, so 'tmux kill-session' would never fire and the
# HUD pane would orphan after codex quits. Run codex as a child instead.
trap "rm -f -- $(printf '%q' "$dispatch_file"); tmux kill-session -t $(printf '%q' "$session") 2>/dev/null" EXIT INT TERM HUP
cd $cwd_q
$codex_full
EOF
tmux new-session -d -s "$session" -x "$(tput cols)" -y "$(tput lines)" "$dispatch_file"
# Capture the codex pane id (the only pane in the session right now) so the
# HUD can detect when it disappears.
codex_pane=$(tmux list-panes -t "$session" -F '#{pane_id}' | head -1)
# Add HUD pane BELOW the codex pane.
hud_pane=$(tmux split-window -v -t "$session" -l "$HUD_HEIGHT" -P -F "#{pane_id}" \
  "CDX_HUD_START_EPOCH=$start_epoch CDX_HUD_CODEX_PANE=$codex_pane CDX_HUD_LAUNCH_CWD=$cwd_q $yolo_hint exec $render_bin_q")
# Pin HUD height across terminal resizes — without these hooks, tmux shrinks
# both panes proportionally on zoom-in and the HUD content gets clipped.
tmux set-hook -t "$session" client-resized \
  "resize-pane -t $hud_pane -y $HUD_HEIGHT" 2>/dev/null || true
tmux set-hook -t "$session" window-resized \
  "resize-pane -t $hud_pane -y $HUD_HEIGHT" 2>/dev/null || true
# Focus codex (the upper pane).
tmux select-pane -t "$session" -U
tmux set-option -t "$session" status off >/dev/null 2>&1 || true
# Pass codex's pane title (which it sets via OSC 2 — model + spinner + task)
# through to the outer terminal tab. Default tmux title would show
# '[<session>] <window> "<command>"' which leaks our tmux session name.
tmux set-option -t "$session" set-titles on >/dev/null 2>&1 || true
tmux set-option -t "$session" set-titles-string '#T' >/dev/null 2>&1 || true
exec tmux attach-session -t "$session"
